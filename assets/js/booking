(function () {
  function submitBookingRequest() {
    var service = document.getElementById('bookingService');
    var name = document.getElementById('bookingName');
    var email = document.getElementById('bookingEmail');
    var phone = document.getElementById('bookingPhone');
    var date = document.getElementById('bookingDate');
    var time = document.getElementById('bookingTime');
    var messageBox = document.getElementById('bookingMessage');

    if (!service || !name || !email || !phone || !date || !time || !messageBox) {
      return;
    }

    if (!name.value || !email.value || !phone.value || !date.value || !time.value) {
      messageBox.textContent = 'Please complete your name, email, phone, preferred date, and preferred time.';
      return;
    }

    messageBox.textContent =
      'Booking request ready: ' +
      service.value +
      ' for ' +
      name.value +
      ' on ' +
      date.value +
      ' at ' +
      time.value +
      '. Connect this form to email or a booking platform to receive live bookings.';
  }

  function initBooking() {
    var bookingSubmit = document.getElementById('bookingSubmit');
    if (bookingSubmit) bookingSubmit.addEventListener('click', submitBookingRequest);
  }

  window.PrestigeBooking = {
    initBooking: initBooking
  };
})();
